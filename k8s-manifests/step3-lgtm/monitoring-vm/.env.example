# monitoring VM 환경변수 예시
# 실제 값을 채워서 .env 파일로 복사:
#   cp .env.example .env
# .env는 .gitignore에 등록됨 (커밋 금지)

# Grafana Slack 알림 웹훅 URL
# 발급: https://api.slack.com/apps → 앱 선택 → Incoming Webhooks → Add New Webhook to Workspace
# 채널: #tutum-alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME/WITH_ACTUAL_TOKEN

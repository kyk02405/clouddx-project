{
  "annotations": { "list": [] },
  "description": "Redis, Kafka, Elasticsearch 데이터 레이어 모니터링",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "🔴 Redis",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Redis 메모리 사용량",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "redis_memory_used_bytes{namespace=\"tutum-data\"}",
          "legendFormat": "Used"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "redis_memory_max_bytes{namespace=\"tutum-data\"}",
          "legendFormat": "Max"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Redis 연결 수 / 명령 처리량",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "redis_connected_clients{namespace=\"tutum-data\"}",
          "legendFormat": "Connected Clients"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(redis_commands_processed_total{namespace=\"tutum-data\"}[1m])",
          "legendFormat": "Commands/s"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit", "min": 0, "max": 1 }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 9 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "colorMode": "background" },
      "title": "Redis 캐시 히트율",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(redis_keyspace_hits_total{namespace=\"tutum-data\"}[5m]) / (rate(redis_keyspace_hits_total{namespace=\"tutum-data\"}[5m]) + rate(redis_keyspace_misses_total{namespace=\"tutum-data\"}[5m]))",
          "legendFormat": "Hit Rate"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101,
      "title": "📨 Kafka",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Kafka Consumer Lag (토픽별)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(kafka_consumer_group_lag{namespace=\"tutum-data\"}) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Kafka 메시지 처리량 (토픽별)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "sum(rate(kafka_topic_partition_current_offset{namespace=\"tutum-data\"}[1m])) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "🔍 Elasticsearch",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 20,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "ES 인덱싱 처리량",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(elasticsearch_indices_indexing_index_total{namespace=\"tutum-data\"}[1m])",
          "legendFormat": "Indexing/s"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 21,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "ES JVM 힙 메모리",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "elasticsearch_jvm_memory_used_bytes{namespace=\"tutum-data\", area=\"heap\"}",
          "legendFormat": "Heap Used"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "elasticsearch_jvm_memory_max_bytes{namespace=\"tutum-data\", area=\"heap\"}",
          "legendFormat": "Heap Max"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["tutum", "redis", "kafka", "elasticsearch"],
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "Asia/Seoul",
  "title": "Tutum - Data Layer",
  "uid": "tutum-data-layer",
  "version": 1
}

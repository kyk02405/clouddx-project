# ============================================
# TUTUM Backend Environment Variables
# ============================================

# MongoDB
MONGO_URI=mongodb://localhost:27017/tutum

# Kafka
KAFKA_BROKERS=localhost:9092

# MinIO (Object Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uploads

# Redis (Optional)
REDIS_URL=redis://localhost:6379

# ============================================
# OCR API - Google Vision 인증
# ============================================
# 프로젝트: project-8f796580-5382-4090-b08
# Organization: rubyjeenkim-org

# 방법 1 (사용 중): API Key 방식
# - API 제한: Cloud Vision API만 허용
# - IP 제한: 팀원 로컬 IP만 허용
GOOGLE_API_KEY=your-google-api-key-here

# 방법 2 (사용 안 함): Service Account JSON 방식
# - Organization Policy 제약으로 인해 SA 키 생성 불가
# - 실제 환경에서는 API Key 방식만 사용
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp_sa.json

# ============================================
# 주의사항
# ============================================
# 1. 현재 프로젝트는 API Key 방식만 사용합니다
# 2. Service Account JSON 키는 Organization Policy로 차단됨
# 3. 실제 API Key는 .env 파일에 설정 (Git 추적 안 됨)

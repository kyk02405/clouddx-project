# ============================================
# TUTUM Backend Environment Variables
# ============================================

# MongoDB
MONGO_URI=mongodb://localhost:27017/tutum

# Kafka
KAFKA_BROKERS=localhost:9092

# MinIO (Object Storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uploads

# Redis (Optional)
REDIS_URL=redis://localhost:6379

# ============================================
# OCR API - Google Vision 인증
# ============================================
# 프로젝트: project-8f796580-5382-4090-b08
# Organization: rubyjeenkim-org

# 방법 1 (사용 중): API Key 방식
# - API 제한: Cloud Vision API만 허용
# - IP 제한: 팀원 로컬 IP만 허용
GOOGLE_API_KEY=your-google-api-key-here

# 방법 2 (사용 안 함): Service Account JSON 방식
# - Organization Policy 제약으로 인해 SA 키 생성 불가
# - 실제 환경에서는 API Key 방식만 사용
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/gcp_sa.json

# ============================================
# 주의사항
# ============================================
# 1. 현재 프로젝트는 API Key 방식만 사용합니다
# 2. Service Account JSON 키는 Organization Policy로 차단됨
# 3. 실제 API Key는 .env 파일에 설정 (Git 추적 안 됨)

# ============================================
# CloudDX Environment Configuration
# ============================================
# 팀원: 이 파일을 backend/.env로 복사하세요
# cp .env.example backend/.env

# ============================================
# MongoDB Atlas (팀 공용)
# ============================================
# 연결 문자열은 팀 리더에게 문의하세요
MONGODB_URL=mongodb+srv://tutum-admin:clouddx@tutum.odoeunm.mongodb.net/?appName=tutum
MONGODB_DB_NAME=clouddx

# ============================================
# JWT Authentication
# ============================================
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# Admin Access Control
# ============================================
# Allowed CIDRs for /api/v1/admin/* (requires login + source IP in this list)
ADMIN_IP_ALLOWLIST=127.0.0.1/8,192.168.0.0/24

# ============================================
# Admin Cost Forecast
# ============================================
# Optional overrides for /api/v1/admin/cost-forecast
# JSON example: {"m6i.large":0.12,"c6g.large":0.088}
ADMIN_COST_INSTANCE_RATES_JSON=
ADMIN_COST_SPOT_INSTANCE_RATES_JSON=
ADMIN_COST_SPOT_DISCOUNT_RATIO=0.35
ADMIN_COST_CONTROL_PLANE_HOURLY_USD=0.10
ADMIN_COST_NAT_GATEWAY_HOURLY_USD=0.045
ADMIN_COST_NAT_GATEWAY_COUNT=0
ADMIN_COST_EXTRA_FIXED_HOURLY_USD=0

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=http://localhost:3000

# ============================================
# Market Data APIs (선택사항)
# ============================================
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_MODE=virtual
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=

# ============================================
# TUTUM 포트폴리오 배포 환경변수
# cp .env.example .env 후 실제 값으로 교체
# ============================================

# MongoDB (Docker 내부 자동 연결)
MONGODB_URL=mongodb://mongodb:27017/clouddx
MONGODB_DB_NAME=clouddx

# MariaDB (RDS 대신 MongoDB로 대체 가능, 없으면 공란)
MARIADB_HOST=
MARIADB_PORT=3306
MARIADB_USER=
MARIADB_PASSWORD=
MARIADB_DATABASE=

# Redis
REDIS_URL=redis://redis:6379

# JWT
SECRET_KEY=<your-jwt-secret-key>

# KIS API (한국투자증권)
KIS_APP_KEY=<your-kis-app-key>
KIS_APP_SECRET=<your-kis-app-secret>
KIS_MODE=real

# Upbit
UPBIT_ACCESS_KEY=<your-upbit-access-key>
UPBIT_SECRET_KEY=<your-upbit-secret-key>

# Google OAuth
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REDIRECT_URI=https://kyungyoon.cloud/api/v1/auth/google/callback

# Kakao OAuth
KAKAO_CLIENT_ID=<your-kakao-client-id>
KAKAO_CLIENT_SECRET=<your-kakao-client-secret>
KAKAO_REDIRECT_URI=https://kyungyoon.cloud/api/v1/auth/kakao/callback

# Naver OAuth
NAVER_CLIENT_ID=<your-naver-client-id>
NAVER_CLIENT_SECRET=<your-naver-client-secret>
NAVER_REDIRECT_URI=https://kyungyoon.cloud/api/v1/auth/naver/callback

# Frontend URL
FRONTEND_URL=https://kyungyoon.cloud

# AWS (개인 계정)
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=<your-aws-access-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-key>

# Bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20251001-v1:0

# Elasticsearch (없으면 공란 - AI 챗봇 MongoDB fallback 사용)
ELASTICSEARCH_URL=

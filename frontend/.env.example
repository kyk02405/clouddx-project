# ===========================
# Frontend Environment Template
# ===========================
# Local development
NEXT_PUBLIC_API_URL=http://localhost:8000
API_BASE_URL=http://localhost:8000

# Optional override for local TLS/proxy environment
# NEXT_PUBLIC_API_URL=https://tutum.my

# Frontend app env must be set in frontend/.env.local for local dev.
# GitLab deploy builds must set the same key as a CI/CD variable.
# Optional admin feature flags
# NEXT_PUBLIC_ADMIN_COST_TAB=true

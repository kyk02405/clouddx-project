# ============================================
# 환경 변수 예시 파일
# ============================================
# .env 파일로 복사 후 실제 값으로 수정하세요
# ============================================

# MongoDB (Node2)
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=clouddx

# Redis (Node2)
REDIS_URL=redis://redis:6379

# Kafka (Node3)
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TICK_TOPIC=price_tick

# Price Vendor (V3)
STOCK_VENDOR=auto
FINNHUB_API_KEY=
POLYGON_API_KEY=
ALLOW_MOCK_PRICE_FEED=false
PRICE_POLL_INTERVAL_SECONDS=5
CRYPTO_MARKETS=KRW-BTC,KRW-ETH,KRW-SOL,KRW-XRP
STOCK_SYMBOLS=AAPL,NVDA,TSLA,MSFT,005930
MAX_TICK_AGE_SECONDS_STOCK=900
MAX_TICK_AGE_SECONDS_CRYPTO=180

# AWS Bedrock
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# MinIO (Node2)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=clouddx-assets

# JWT 인증 (운영 환경에서는 반드시 변경!)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:3000"]

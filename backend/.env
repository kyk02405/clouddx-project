# ============================================
# MinIO (파일 스토리지 - OCR 이미지, 프로필)
# ============================================
# S3 호환 오브젝트 스토리지 (Node2에서 Docker로 실행)
# 로컬 개발: 192.168.0.28:9000 (Node2 공인 IP)
# 운영: Node2 내부 IP(192.168.56.XX:9000)로 변경
MINIO_ENDPOINT="192.168.0.28:9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_SECURE=False                  # True 시 HTTPS 사용
MINIO_BUCKET_OCR="ocr-images"       # OCR 업로드 이미지 버킷
MINIO_BUCKET_PROFILE="profile-images"   # 사용자 프로필 이미지 버킷

# ============================================
# JWT 인증 시크릿

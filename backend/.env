# 앱 기본 설정
APP_NAME="CloudDX Asset Management API"
DEBUG=True                          # 운영 배포 시 False로 변경

# ============================================
# MongoDB (Atlas Cloud - 뉴스/자산 데이터)
# ============================================
# MongoDB Atlas 클라우드 서비스 사용 (Node2 아님)
# 뉴스 컬렉션(news), 자산 컬렉션(assets) 저장
# chat_service에서 ES 실패 시 fallback으로 사용
MONGODB_URL="mongodb+srv://tutum-admin:clouddx@tutum.odoeunm.mongodb.net/?appName=tutum"
MONGODB_DB_NAME="clouddx"

# ============================================
# MariaDB (학원 제공 외부 서버 - 사용자/포트폴리오)
# ============================================
# 사용자 계정, 포트폴리오, 거래 내역 저장
# 접속 불가 시 MongoDB fallback으로 전환됨

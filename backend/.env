# ============================================
# AWS Bedrock (AI 채팅 + 임베딩 생성)
# ============================================
# 용도 1: Claude 모델로 AI 채팅 답변 생성 (chat_service.py)
# 용도 2: Titan Embed 모델로 뉴스 임베딩 생성 (Node3 consumer)
# 리전: ap-northeast-2 (서울) - Bedrock 모델 지원 리전
AWS_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID="AKIA5E5LPAK2PQPJG3OR"
AWS_SECRET_ACCESS_KEY="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"
